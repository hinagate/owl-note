{
  "manifest_version": 3,
  "name": "OWL-Note",
  "version": "1.9.7",
  "description": "Free Markdown notes with code & math in browser bookmarks. Syncs via Google/Microsoft. Private, no subscriptions or lock-in.",
  "permissions": ["bookmarks", "storage", "unlimitedStorage", "contextMenus", "identity"],
  "optional_host_permissions": ["https://www.googleapis.com/*", "https://oauth2.googleapis.com/*"],
  "action": { "default_title": "Open OWL-Note" },
  "background": { "service_worker": "service-worker.js" },
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
